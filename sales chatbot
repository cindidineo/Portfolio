<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Ava - Neurofive Sales Assistant</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  
  body { 
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; 
    background: linear-gradient(135deg, #0f172a 0%, #1a1f3a 100%);
    color: #fff; 
    display: flex; 
    justify-content: center; 
    align-items: center; 
    min-height: 100vh; 
    padding: 20px;
  }
  
  .chat-container { 
    width: 100%; 
    max-width: 450px; 
    height: 600px; 
    background: #1e293b; 
    border-radius: 16px; 
    display: flex; 
    flex-direction: column; 
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.7);
    border: 1px solid #334155;
  }
  
  .chat-header { 
    background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
    padding: 20px; 
    border-radius: 16px 16px 0 0; 
    text-align: center; 
    font-weight: 600; 
    font-size: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
  }
  
  .status-indicator {
    width: 10px;
    height: 10px;
    background: #22c55e;
    border-radius: 50%;
    animation: pulse 2s infinite;
  }
  
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }
  
  .chat-box { 
    flex: 1; 
    padding: 20px; 
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  
  .message { 
    padding: 12px 16px; 
    border-radius: 18px; 
    max-width: 85%; 
    line-height: 1.5;
    word-wrap: break-word;
    animation: slideIn 0.3s ease-out;
  }
  
  @keyframes slideIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  .user { 
    background: #2563eb; 
    margin-left: auto; 
    text-align: right;
    align-self: flex-end;
  }
  
  .ava { 
    background: #334155; 
    margin-right: auto;
    align-self: flex-start;
  }
  
  .typing-indicator {
    display: flex;
    gap: 4px;
    padding: 12px 16px;
  }
  
  .typing-dot {
    width: 8px;
    height: 8px;
    background: #94a3b8;
    border-radius: 50%;
    animation: typing 1.4s infinite;
  }
  
  .typing-dot:nth-child(2) {
    animation-delay: 0.2s;
  }
  
  .typing-dot:nth-child(3) {
    animation-delay: 0.4s;
  }
  
  @keyframes typing {
    0%, 60%, 100% { opacity: 0.5; }
    30% { opacity: 1; }
  }
  
  .chat-input { 
    display: flex; 
    padding: 16px; 
    border-top: 1px solid #334155;
    gap: 10px;
    background: #0f172a;
    border-radius: 0 0 16px 16px;
  }
  
  .chat-input input { 
    flex: 1; 
    padding: 12px 16px; 
    border: 1px solid #334155;
    border-radius: 24px; 
    background: #1e293b; 
    color: #fff;
    outline: none;
    transition: border-color 0.3s;
    font-size: 14px;
  }
  
  .chat-input input:focus {
    border-color: #2563eb;
  }
  
  .chat-input input::placeholder {
    color: #64748b;
  }
  
  .chat-input button { 
    padding: 12px 24px; 
    background: #2563eb; 
    border: none; 
    border-radius: 24px; 
    color: #fff; 
    cursor: pointer;
    font-weight: 600;
    transition: all 0.3s;
    min-width: 60px;
  }
  
  .chat-input button:hover { 
    background: #1d4ed8;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(37, 99, 235, 0.4);
  }
  
  .chat-input button:active {
    transform: translateY(0);
  }
  
  .chat-input button:disabled {
    background: #64748b;
    cursor: not-allowed;
    transform: none;
  }
  
  .error-message {
    background: #dc2626;
    padding: 12px 16px;
    border-radius: 8px;
    margin: 10px;
    font-size: 14px;
  }
  
  .config-note {
    background: #f59e0b;
    color: #000;
    padding: 12px;
    border-radius: 8px;
    margin: 10px;
    font-size: 13px;
    display: none;
  }
  
  .config-note.show {
    display: block;
  }

  ::-webkit-scrollbar {
    width: 6px;
  }

  ::-webkit-scrollbar-track {
    background: #0f172a;
  }

  ::-webkit-scrollbar-thumb {
    background: #334155;
    border-radius: 3px;
  }

  ::-webkit-scrollbar-thumb:hover {
    background: #475569;
  }
</style>
</head>
<body>

<div class="chat-container">
  <div class="chat-header">
    <div class="status-indicator"></div>
    Ava - Neurofive Sales Assistant
  </div>
  <div class="config-note" id="configNote">
    ⚠️ API Key not configured. Add your OpenAI API key to make the chatbot work.
  </div>
  <div class="chat-box" id="chatBox">
    <div class="message ava">Hi! I'm Ava from Neurofive Solutions 👋 How can I help you find the right product today?</div>
  </div>
  <div class="chat-input">
    <input type="text" id="userInput" placeholder="Type your message..." />
    <button id="sendBtn" onclick="sendMessage()">Send</button>
  </div>
</div>

<script>
// Configuration
const CONFIG = {
  API_KEY: localStorage.getItem("openai_api_key") || "",
  API_ENDPOINT: "https://api.openai.com/v1/chat/completions",
  MODEL: "gpt-4o-mini",
  MAX_TOKENS: 200,
  TEMPERATURE: 0.8
};

const SYSTEM_PROMPT = `
You are "Ava", the friendly and professional Sales Assistant for Neurofive Solutions.

About Neurofive Solutions:
1. Neurofive App: AI productivity tools for teams to automate tasks and save time
2. Neurofive Store: Premium tech gadgets - wireless headphones, smart watches, laptop bags, laptops
3. Neurofive Cloud: Secure, fast cloud storage and backup for businesses

RULES:
1. Be warm, helpful, and consultative. Never be pushy.
2. Ask questions to understand their problem before recommending.
3. When recommending, list 2-3 key benefits and give a clear next step: "Want pricing, a demo, or a link?"
4. Keep replies under 120 words and conversational.
5. If asked about pricing: "I can connect you with sales@neurofive.com for exact pricing."
6. If the question is off-topic, politely steer back to Neurofive products.
7. Always end with a question.
`;

let messages = [
  { role: "system", content: SYSTEM_PROMPT },
  { role: "assistant", content: "Hi! I'm Ava from Neurofive Solutions 👋 How can I help you find the right product today?" }
];

let isLoading = false;

function checkApiKey() {
  const configNote = document.getElementById("configNote");
  if (!CONFIG.API_KEY || CONFIG.API_KEY === "sk-YOUR_API_KEY_HERE") {
    configNote.classList.add("show");
    return false;
  }
  configNote.classList.remove("show");
  return true;
}

function addTypingIndicator() {
  const chatBox = document.getElementById("chatBox");
  const typingDiv = document.createElement("div");
  typingDiv.className = "typing-indicator ava";
  typingDiv.id = "typingIndicator";
  typingDiv.innerHTML = '<div class="typing-dot"></div><div class="typing-dot"></div><div class="typing-dot"></div>';
  chatBox.appendChild(typingDiv);
  chatBox.scrollTop = chatBox.scrollHeight;
}

function removeTypingIndicator() {
  const typingIndicator = document.getElementById("typingIndicator");
  if (typingIndicator) {
    typingIndicator.remove();
  }
}

async function sendMessage() {
  if (!checkApiKey()) {
    const chatBox = document.getElementById("chatBox");
    chatBox.innerHTML += `<div class="message ava">⚠️ API Key not configured. Please set your OpenAI API key to use this chatbot.</div>`;
    return;
  }

  const input = document.getElementById("userInput");
  const chatBox = document.getElementById("chatBox");
  const sendBtn = document.getElementById("sendBtn");
  const userText = input.value.trim();
  
  if (!userText || isLoading) return;

  // Show user message
  const userMessageDiv = document.createElement("div");
  userMessageDiv.className = "message user";
  userMessageDiv.textContent = userText;
  chatBox.appendChild(userMessageDiv);
  
  messages.push({ role: "user", content: userText });
  input.value = "";
  chatBox.scrollTop = chatBox.scrollHeight;

  // Show loading state
  isLoading = true;
  sendBtn.disabled = true;
  addTypingIndicator();

  try {
    const response = await fetch(CONFIG.API_ENDPOINT, {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        "Authorization": `Bearer ${CONFIG.API_KEY}`
      },
      body: JSON.stringify({
        model: CONFIG.MODEL,
        messages: messages,
        max_tokens: CONFIG.MAX_TOKENS,
        temperature: CONFIG.TEMPERATURE
      })
    });

    if (!response.ok) {
      throw new Error(`API Error: ${response.status} - ${response.statusText}`);
    }

    const data = await response.json();
    
    if (!data.choices || !data.choices[0] || !data.choices[0].message) {
      throw new Error("Invalid API response");
    }

    const avaReply = data.choices[0].message.content;
    messages.push({ role: "assistant", content: avaReply });

    // Remove typing indicator
    removeTypingIndicator();

    // Show Ava's reply
    const avaMessageDiv = document.createElement("div");
    avaMessageDiv.className = "message ava";
    avaMessageDiv.textContent = avaReply;
    chatBox.appendChild(avaMessageDiv);
    chatBox.scrollTop = chatBox.scrollHeight;

  } catch (error) {
    removeTypingIndicator();
    const errorDiv = document.createElement("div");
    errorDiv.className = "message ava";
    errorDiv.textContent = `❌ Error: ${error.message}. Please check your API key and try again.`;
    chatBox.appendChild(errorDiv);
    chatBox.scrollTop = chatBox.scrollHeight;
  } finally {
    isLoading = false;
    sendBtn.disabled = false;
  }
}

// Send on Enter key
document.getElementById("userInput").addEventListener("keypress", function(e) {
  if (e.key === "Enter" && !isLoading) {
    sendMessage();
  }
});

// Check API key on load
window.addEventListener("load", checkApiKey);

// Allow setting API key via URL parameter or localStorage
function setApiKey(key) {
  CONFIG.API_KEY = key;
  localStorage.setItem("openai_api_key", key);
  checkApiKey();
}

// Expose for debugging
window.setApiKey = setApiKey;
</script>

</body>
</html>
